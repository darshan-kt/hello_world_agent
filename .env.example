# ──────────────────────────────────────────────────────────
# Hello Agent — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────

# Which LLM provider to use: gemini (default) or groq
# Groq's free tier allows far more requests/day than Gemini's — switch to it
# if you're hitting Gemini's daily quota during testing.
LLM_PROVIDER=gemini

# Get your key at: https://aistudio.google.com/apikey (FREE)
GEMINI_API_KEY=[GCP_API_KEY]

# Model to use (gemini-2.5-flash is fast + free)
LLM_MODEL=gemini-2.5-flash

# Get your key at: https://console.groq.com/keys (FREE) — only needed if LLM_PROVIDER=groq
GROQ_API_KEY=[GROQ_API_KEY]

# Model to use (gpt-oss-120b tested most reliable for multi-step tool calling on Groq)
GROQ_MODEL=openai/gpt-oss-120b

# Agent personality
AGENT_NAME=Darshan-AI

# How creative? 0.0 = robotic, 1.0 = creative
LLM_TEMPERATURE=0.2

# Max tool-call loops per question (prevents infinite loops)
MAX_ITERATIONS=10

# How many messages to remember
MEMORY_WINDOW=20

# API server
API_HOST=0.0.0.0
API_PORT=8000
