# ──────────────────────────────────────────────────────────
# Hello Agent — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────

# Get your key at: https://aistudio.google.com/apikey (FREE)
GEMINI_API_KEY=[GCP_API_KEY]

# Model to use (gemini-2.5-flash is fast + free)
LLM_MODEL=gemini-2.5-flash

# Agent personality
AGENT_NAME=Darshan-AI

# How creative? 0.0 = robotic, 1.0 = creative
LLM_TEMPERATURE=0.2

# Max tool-call loops per question (prevents infinite loops)
MAX_ITERATIONS=10

# How many messages to remember
MEMORY_WINDOW=20

# API server
API_HOST=0.0.0.0
API_PORT=8000
